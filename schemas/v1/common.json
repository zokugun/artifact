{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://raw.githubusercontent.com/zokugun/artifact/v0.6.0/schemas/v1/common.json",
	"$defs": {
		"always": {
			"type": "object",
			"properties": {
				"if_exists": {
					"type": "string",
					"enum": [
						"merge",
						"overwrite",
						"remove",
						"skip"
					]
				},
				"transforms": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/transform"
					}
				}
			},
			"additionalProperties": false
		},
		"install": {
			"allOf": [
				{
					"$ref": "#/$defs/upsert"
				}
			]
		},
		"transform": {
			"type": "object",
			"properties": {
				"description": {
					"type": "string"
				},
				"jq": {
					"type": "string"
				}
			},
			"required": [
				"jq"
			],
			"additionalProperties": false
		},
		"uninstall": {
			"allOf": [
				{
					"$ref": "#/$defs/always"
				},
				{
					"type": "object",
					"properties": {
						"if_exists": {
							"type": "string",
							"enum": [
								"remove",
								"skip",
								"unmerge"
							]
						}
					},
					"additionalProperties": false
				}
			]
		},
		"update": {
			"allOf": [
				{
					"$ref": "#/$defs/upsert"
				}
			]
		},
		"upsert": {
			"allOf": [
				{
					"$ref": "#/$defs/always"
				},
				{
					"type": "object",
					"properties": {
						"filter": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"if_missing": {
							"type": "string",
							"enum": [
								"merge",
								"skip"
							]
						},
						"route": {
							"type": "object",
							"additionalProperties": true
						}
					},
					"additionalProperties": false
				}
			]
		}
	}
}
