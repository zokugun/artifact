{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://raw.githubusercontent.com/zokugun/artifact/v0.6.0/schemas/v0/install.json",
	"$defs": {
		"artifact": {
			"type": "object",
			"properties": {
				"version": {
					"type": "string"
				},
				"provides": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"requires": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			},
			"required": [
				"version"
			],
			"additionalProperties": false
		}
	},
	"type": "object",
	"properties": {
		"artifacts": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/$defs/artifact"
			}
		},
		"constants": {
			"type": "object",
			"additionalProperties": {
				"type": "string"
			}
		},
		"install": {
			"type": "object",
			"additionalProperties": {
				"$ref": "https://raw.githubusercontent.com/zokugun/artifact/v0.6.0/schemas/v0/common.json#/$defs/install"
			}
		},
		"update": {
			"oneOf": [
				{
					"const": false
				},
				{
					"type": "object",
					"additionalProperties": {
						"$ref": "https://raw.githubusercontent.com/zokugun/artifact/v0.6.0/schemas/v0/common.json#/$defs/update"
					}
				}
			]
		},
		"variables": {
			"type": "object",
			"additionalProperties": {
				"type": "string"
			}
		}
	},
	"additionalProperties": false
}
