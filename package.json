{
	"name": "@zokugun/artifact",
	"description": "Boilerplate your project & keep your configurations up to date",
	"version": "0.5.2",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/artifact",
	"repository": {
		"type": "git",
		"url": "https://github.com/zokugun/artifact.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/artifact/discussions/categories/issue-triage"
	},
	"engines": {
		"node": ">=18.20"
	},
	"bin": {
		"artifact": "bin/artifact",
		"atf": "bin/artifact"
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run compile:src",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf .test lib",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "fixpack && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"prepublishOnly": "npm run compile",
		"release": "release-it",
		"test": "tsc -p test && mocha",
		"test:dev": "mocha",
		"test:watch": "tsc-watch -p src -p test --onSuccess 'mocha -g=\"\"'",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src",
		"watch:test": "tsc-watch -p test"
	},
	"dependencies": {
		"@zokugun/cli-utils": "0.3.0",
		"@zokugun/configdotts-merge": "0.2.0",
		"@zokugun/is-it-type": "^0.8.1",
		"dayjs": "1.11.20",
		"detect-indent": "6.1.0",
		"editorconfig": "0.15.3",
		"fs-extra": "10.1.0",
		"globby": "11.1.0",
		"istextorbinary": "6.0.0",
		"jsonc-parser": "3.3.1",
		"lodash-es": "4.18.1",
		"micromatch": "4.0.8",
		"pacote": "21.5.0",
		"semver": "7.7.4",
		"tempy": "1.0.1",
		"untildify": "4.0.0",
		"yaml": "2.8.3"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/chai": "4.3.20",
		"@types/chai-as-promised": "7.1.8",
		"@types/fs-extra": "9.0.13",
		"@types/lodash-es": "4.17.12",
		"@types/micromatch": "4.0.10",
		"@types/mocha": "9.1.1",
		"@types/node": "20.19.39",
		"@types/npm": "7.19.3",
		"@types/pacote": "11.1.8",
		"@types/semver": "7.7.1",
		"@types/universalify": "1.0.3",
		"camelcase": "6.3.0",
		"chai": "4.5.0",
		"chai-as-promised": "7.1.2",
		"eslint": "8.11.0",
		"eslint-plugin-chai-friendly": "0.7.4",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"memfs": "3.6.0",
		"mocha": "9.2.2",
		"release-it": "20.0.0-1",
		"rewiremock": "3.14.6",
		"source-map-support": "0.5.21",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"universalify": "2.0.1",
		"xo": "0.60.0"
	},
	"overrides": {
		"mocha": {
			"diff": "5.2.2",
			"js-yaml": "4.1.1",
			"minimatch": "4.2.6",
			"nanoid": "3.3.11",
			"serialize-javascript": "7.0.5"
		}
	},
	"keywords": [
		"artifact",
		"boilerplate",
		"boilerplates",
		"codegeneration",
		"codemod",
		"codemods",
		"configuration",
		"configurations",
		"generate",
		"generator",
		"project-generator",
		"project-starter",
		"project-template",
		"scaffold"
	]
}
